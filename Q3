#E.) Calculator
def simple_calc (eq):

    split_parts = eq.split()

    a = float(split_parts[0])

    op = (split_parts[1])

    b = float(split_parts [2])

    if op == "+":
        return add(a,b)

    elif op == "-":
        return sub(a,b)

    elif op == "*":
        return mult(a,b)

    if op == "/":
        return div(a,b)

print (simple_calc("3 * 5"))





