def sub(a, b):
    sub = a - b
    if sub <= 0:
        return(0)


    elif sub >= 0:
        return sub

print (sub(6,7))

#C.)
def mult(a, b):
    mult = a * b

    if mult <= 0:
        return(0)

    elif mult >= 0:
        return a * b

print (mult(1,-4))

