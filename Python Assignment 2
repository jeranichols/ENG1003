import pandas as pd
import matplotlib.pyplot as plt
import math
import numpy as np
import rootfinding as rf


def plot_water_tank_data(data_file_path):
    fig, ax = plt.subplots()

    csv_data = pd.read_csv(data_file_path)

    height = csv_data['Height']

    velocity = csv_data['Velocity']


    ax.plot(height, velocity)
    ax.set_title('Water Velocity vs Water Height in Tank')
    ax.set_xlabel('Height [M]')
    ax.set_ylabel('Velocity[m/s]')

    return fig,ax

#b.)
def water_height_required(velocity):

    g = 9.81
    L = 5 #length of pipe in meters
    v = velocity

    def f(h):
        equation = math.sqrt(2 * g * h) * np.tanh(2 / L * math.sqrt(2 * g * h))
        return equation - v


    height = rf.secant(f, 0.5, 3, 200)
    return height

